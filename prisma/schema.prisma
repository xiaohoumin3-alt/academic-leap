// Prisma Schema for 学力跃迁 (Academic Leap)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 用户模型
model User {
  id          String    @id @default(cuid())
  email       String    @unique
  name        String?
  password    String
  grade       Int       // 年级: 1-12
  targetScore Int       @default(90) // 目标分数
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // 测评相关字段
  initialAssessmentCompleted  Boolean   @default(false)  // 是否完成初始测评
  initialAssessmentScore     Int?                       // 初始测评等效分
  initialAssessmentDate      DateTime?                  // 初始测评日期
  reviewAssessmentCompleted  Boolean   @default(false)  // 是否完成复测评
  reviewAssessmentScore      Int?                       // 复测评等效分
  reviewAssessmentDate       DateTime?                  // 复测评日期
  currentLevel               Int       @default(0)     // 当前学力等级
  startingScoreCalibrated    Boolean   @default(false) // 是否已完成起始分校准
  calibratedStartingScore    Int?                      // 校准后的起始分数

  // 年级科目教材设置
  selectedSubject    String?   // 选择的科目 (数学)
  selectedTextbookId String?   // 选择的教材版本ID
  studyProgress      Int       @default(0) // 学习进度百分比 0-100 (已废弃，保留兼容)
  semesterStart      DateTime? // 学期开始日期
  semesterEnd        DateTime? // 学期结束日期

  // 学习路径偏好（新增）
  includeStale      Boolean @default(false)  // 是否包含久未练习的已掌握知识点
  pathUpdateMode    String  @default("auto") // 'auto' | 'manual'
  weeklyReportDay   Int     @default(0)      // 0=周日, 1=周一, ...

  // 关联
  attempts            Attempt[]
  knowledge           UserKnowledge[]
  ocrTasks            OCRTask[]
  accounts            Account[]
  sessions            Session[]
  admin               Admin?
  assessments         Assessment[]
  enabledKnowledge    UserEnabledKnowledge[]
  learningPaths       LearningPath[]
}

// 题目模型
model Question {
  id             String    @id @default(cuid())
  type           String    // calculation/geometry/algebra
  difficulty     Int       // 1-5
  content        String   @default("{}") // 题目内容（JSON字符串）
  answer         String
  hint           String?
  knowledgePoints String  @default("[]") // 知识点标签(JSON字符串)
  createdBy      String?   // admin id
  isAI           Boolean   @default(false)
  createdAt      DateTime  @default(now())

  // 新增：题目引擎相关字段
  templateId     String?   // 关联模板ID
  params         String?   @default("{}") // 参数JSON {a:1, b:-4, c:3}
  stepTypes      String?   @default("[]") // 步骤类型JSON ['compute_vertex_x', ...]

  // 关联
  steps    QuestionStep[]
}

// 题目步骤模型
model QuestionStep {
  id         String   @id @default(cuid())
  questionId String
  stepNumber Int
  expression String
  answer     String
  hint       String?

  // 新增：题目引擎相关字段
  type       String?  // StepType枚举值
  inputType  String?  // numeric/coordinate/fraction/expression
  tolerance  Float?   // 容差
  keyboard   String?  // numeric/coordinate/fraction/full

  question   Question      @relation(fields: [questionId], references: [id], onDelete: Cascade)
  attempts   AttemptStep[]
}

// 练习记录
model Attempt {
  id          String    @id @default(cuid())
  userId      String
  mode        String    // training/diagnostic
  score       Int
  duration    Int       // 秒
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  steps       AttemptStep[]
}

// 练习步骤记录
model AttemptStep {
  id            String   @id @default(cuid())
  attemptId     String
  questionStepId String?
  stepNumber    Int
  userAnswer    String
  isCorrect     Boolean
  duration      Int      // 毫秒
  submittedAt   DateTime @default(now())

  attempt       Attempt         @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionStep  QuestionStep?   @relation(fields: [questionStepId], references: [id], onDelete: SetNull)
}

// 用户知识点掌握
model UserKnowledge {
  id             String    @id @default(cuid())
  userId         String
  knowledgePoint String
  mastery        Float     // 0-1 掌握度
  lastPractice   DateTime  @default(now())
  practiceCount  Int       @default(0)

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, knowledgePoint])
}

// OCR识别任务
model OCRTask {
  id         String    @id @default(cuid())
  userId     String
  imageUrl   String
  status     String    // pending/processing/completed/failed
  result     String? @default("{}") // JSON字符串
  createdAt  DateTime  @default(now())

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// NextAuth.js Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// 管理员用户（扩展User）
model Admin {
  id        String   @id @default(cuid())
  userId    String   @unique
  role      String   @default("viewer") // admin/editor/viewer
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  auditLogs AuditLog[]
  templates Template[]
}

// 知识点概念（双层架构）
model KnowledgeConcept {
  id          String    @id @default(cuid())
  name        String    // "勾股定理"
  category    String?   // "几何"、"代数"
  weight      Int       @default(0) // 默认权重
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  instances   KnowledgePoint[]
}

// 教材版本
model TextbookVersion {
  id          String   @id @default(cuid())
  name        String   // "人教版", "北师大版"
  publisher   String?  // "人民教育出版社"
  grade       Int      // 7-12
  subject     String   // "数学"
  year        String?  // "2024版"
  status      String   @default("active")
  chapters    Chapter[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([grade, subject, name])
  @@index([grade, subject, status])
}

// 教材章节
model Chapter {
  id              String           @id @default(cuid())
  textbookId      String           // 关联教材版本
  chapterNumber   Int              // 第几章
  chapterName     String           // "有理数"
  sectionNumber   Int?             // 第几节（可选）
  sectionName     String?          // 小节名称
  parentId        String?          // 父章节ID（用于小节）
  sort            Int              @default(0)

  textbook        TextbookVersion  @relation(fields: [textbookId], references: [id])
  parent          Chapter?         @relation("ChapterHierarchy", fields: [parentId], references: [id])
  children        Chapter[]        @relation("ChapterHierarchy")
  knowledgePoints KnowledgePoint[]

  @@index([textbookId, parentId])
}

// 用户勾选的知识点/章节
model UserEnabledKnowledge {
  id        String   @id @default(cuid())
  userId    String
  nodeId    String   // 章节ID或知识点ID
  nodeType  String   // "chapter" 或 "point"
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, nodeId])
  @@index([userId, nodeType])
}

// 知识点（实例层）
model KnowledgePoint {
  id          String    @id @default(cuid())
  chapterId   String    // 关联章节
  conceptId   String    // 关联概念
  name        String    // 实例名称（可覆盖概念名）
  weight      Int       @default(0) // 权重：0=使用概念权重，>0=覆盖
  inAssess    Boolean   @default(true) // 参与测评
  status      String    @default("active") // active/draft/archived
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  chapter     Chapter              @relation(fields: [chapterId], references: [id])
  concept     KnowledgeConcept     @relation(fields: [conceptId], references: [id])
  histories   KnowledgePointHistory[]
  templates   Template[]
}

// 知识点变更历史
model KnowledgePointHistory {
  id          String   @id @default(cuid())
  knowledgeId String
  field       String   // weight/inAssess/status
  oldValue    String
  newValue    String
  operator    String   // admin userId
  reason      String?
  createdAt   DateTime @default(now())

  knowledge   KnowledgePoint @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)
}

// 题目模板
model Template {
  id          String    @id @default(cuid())
  name        String
  type        String    // calculation/geometry/worded
  templateKey String?   // 对应 TEMPLATE_REGISTRY 的 key（如 linear_equation, quadratic_vertex）
  structure   Json      // 方程结构定义
  params      Json      // 参数约束
  steps       Json      // 解题步骤
  version     Int       @default(1)
  status      String    @default("draft") // draft/staging/production
  knowledgeId String?   // 关联知识点
  createdBy   String    // admin userId
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  creator     Admin     @relation(fields: [createdBy], references: [id])
  knowledge   KnowledgePoint? @relation(fields: [knowledgeId], references: [id])
  qualities   QuestionQuality[]
  versions    TemplateVersion[]
}

// 模板版本历史
model TemplateVersion {
  id         String   @id @default(cuid())
  templateId String
  version    Int
  structure  Json
  params     Json
  steps      Json
  createdBy  String
  createdAt  DateTime @default(now())

  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

// 题目质量检测
model QuestionQuality {
  id          String    @id @default(cuid())
  templateId  String
  checkType   String    // infinite_solution/duplicate/symbol_conflict
  status      String    // passed/warning/error
  details     Json      // 检测详情
  sampleData  Json?     // 样本数据
  detectedAt  DateTime  @default(now())
  resolvedAt  DateTime?

  template    Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

// 操作审计日志
model AuditLog {
  id        String   @id @default(cuid())
  userId    String   // admin userId
  action    String   // create/update/delete/publish
  entity    String   // knowledge/template/difficulty
  entityId  String
  changes   Json     // 变更内容
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  admin     Admin @relation(fields: [userId], references: [id])
}

// 测评记录
model Assessment {
  id            String   @id @default(cuid())
  userId        String
  type          String   // 'initial' | 'review'
  score         Int      // 等效分
  scoreRangeLow Int      // 波动区间下限
  scoreRangeHigh Int     // 波动区间上限
  knowledgeData Json     // 各知识点掌握详情 {knowledgePoint: {level, mastery, correctCount, totalCount}}
  completedAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// 学习路径
model LearningPath {
  id                String   @id @default(cuid())
  userId            String
  name              String   // "2024秋季学期学习路径"
  type              String   // 'initial' | 'weekly' | 'manual'
  status            String   @default("active") // active/archived
  knowledgeData     String   @default("[]") // JSON字符串: [{nodeId, priority, status, addedAt, reasons}]
  generatedAt       DateTime @default(now())
  expiresAt         DateTime? // 周路径的过期时间

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  adjustments       PathAdjustment[]
  weeklyReports     WeeklyReport[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId, status])
}

// 路径调整记录
model PathAdjustment {
  id                String   @id @default(cuid())
  pathId            String
  type              String   // 'micro' | 'weekly'
  trigger           String   // 'practice_completed' | 'weekly_recalibration'
  changes           String   @default("{}") // JSON字符串: {added: [], removed: [], reordered: []}
  createdAt         DateTime @default(now())

  path              LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)

  @@index([pathId, createdAt])
}

// 周报
model WeeklyReport {
  id                String   @id @default(cuid())
  pathId            String
  weekStart         DateTime
  weekEnd           DateTime
  summary           String   @default("{}") // JSON字符串: {practicedCount, masteredCount, weakCount}
  staleKnowledge    String   @default("[]") // JSON字符串: [{nodeId, lastPractice, mastery}]
  recommendations   String   @default("{}") // JSON字符串: {toReview: [], toLearn: []}
  viewed           Boolean  @default(false)

  path              LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)

  createdAt         DateTime @default(now())

  @@index([pathId, weekStart])
}
