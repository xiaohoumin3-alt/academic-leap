generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                         String                 @id @default(cuid())
  email                      String                 @unique
  name                       String?
  password                   String
  grade                      Int
  targetScore                Int                    @default(90)
  createdAt                  DateTime               @default(now())
  updatedAt                  DateTime               @updatedAt
  initialAssessmentCompleted Boolean                @default(false)
  initialAssessmentScore     Int?
  initialAssessmentDate      DateTime?
  reviewAssessmentCompleted  Boolean                @default(false)
  reviewAssessmentScore      Int?
  reviewAssessmentDate       DateTime?
  currentLevel               Int                    @default(0)
  startingScoreCalibrated    Boolean                @default(false)
  calibratedStartingScore    Int?
  selectedSubject            String?
  selectedTextbookId         String?
  studyProgress              Int                    @default(0)
  semesterStart              DateTime?
  semesterEnd                DateTime?
  includeStale               Boolean                @default(false)
  pathUpdateMode             String                 @default("auto")
  weeklyReportDay            Int                    @default(0)
  accounts                   Account[]
  admin                      Admin?
  assessments                Assessment[]
  attempts                   Attempt[]
  learningPaths              LearningPath[]
  ocrTasks                   OCRTask[]
  sessions                   Session[]
  enabledKnowledge           UserEnabledKnowledge[]
  knowledge                  UserKnowledge[]
}

model Question {
  id              String         @id @default(cuid())
  type            String
  difficulty      Int
  content         String         @default("{}")
  answer          String
  hint            String?
  knowledgePoints String         @default("[]")
  createdBy       String?
  isAI            Boolean        @default(false)
  createdAt       DateTime       @default(now())
  params          String?        @default("{}")
  stepTypes       String?        @default("[]")
  templateId      String?
  steps           QuestionStep[]
}

model QuestionStep {
  id         String        @id @default(cuid())
  questionId String
  stepNumber Int
  expression String
  answer     String
  hint       String?
  inputType  String?
  keyboard   String?
  tolerance  Float?
  type       String?
  attempts   AttemptStep[]
  question   Question      @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model Attempt {
  id          String        @id @default(cuid())
  userId      String
  mode        String
  score       Int
  duration    Int
  startedAt   DateTime      @default(now())
  completedAt DateTime?
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  steps       AttemptStep[]
}

model AttemptStep {
  id             String        @id @default(cuid())
  attemptId      String
  questionStepId String?
  stepNumber     Int
  userAnswer     String
  isCorrect      Boolean
  duration       Int
  submittedAt    DateTime      @default(now())
  questionStep   QuestionStep? @relation(fields: [questionStepId], references: [id])
  attempt        Attempt       @relation(fields: [attemptId], references: [id], onDelete: Cascade)
}

model UserKnowledge {
  id               String         @id @default(cuid())
  userId           String
  knowledgePointId String
  mastery          Float
  lastPractice     DateTime       @default(now())
  practiceCount    Int            @default(0)
  knowledgePoint   KnowledgePoint @relation(fields: [knowledgePointId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, knowledgePointId])
}

model OCRTask {
  id        String   @id @default(cuid())
  userId    String
  imageUrl  String
  status    String
  result    String?  @default("{}")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Admin {
  id        String     @id @default(cuid())
  userId    String     @unique
  role      String     @default("viewer")
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  auditLogs AuditLog[]
  templates Template[]
}

model KnowledgeConcept {
  id        String           @id @default(cuid())
  name      String
  category  String?
  weight    Int              @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  instances KnowledgePoint[]
  templates Template[]       @relation("TemplateConcept")
}

model TextbookVersion {
  id        String    @id @default(cuid())
  name      String
  publisher String?
  grade     Int
  subject   String
  year      String?
  status    String    @default("active")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  chapters  Chapter[]

  @@unique([grade, subject, name])
  @@index([grade, subject, status])
}

model Chapter {
  id              String           @id @default(cuid())
  textbookId      String
  chapterNumber   Int
  chapterName     String
  sectionNumber   Int?
  sectionName     String?
  parentId        String?
  sort            Int              @default(0)
  parent          Chapter?         @relation("ChapterHierarchy", fields: [parentId], references: [id])
  children        Chapter[]        @relation("ChapterHierarchy")
  textbook        TextbookVersion  @relation(fields: [textbookId], references: [id])
  knowledgePoints KnowledgePoint[]

  @@index([textbookId, parentId])
}

model UserEnabledKnowledge {
  id        String   @id @default(cuid())
  userId    String
  nodeId    String
  nodeType  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, nodeId])
  @@index([userId, nodeType])
}

model KnowledgePoint {
  id            String                  @id @default(cuid())
  chapterId     String
  conceptId     String
  name          String
  weight        Int                     @default(0)
  inAssess      Boolean                 @default(true)
  status        String                  @default("active")
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  deletedAt     DateTime?
  concept       KnowledgeConcept        @relation(fields: [conceptId], references: [id])
  chapter       Chapter                 @relation(fields: [chapterId], references: [id])
  histories     KnowledgePointHistory[]
  userKnowledge UserKnowledge[]
}

model KnowledgePointHistory {
  id          String         @id @default(cuid())
  knowledgeId String
  field       String
  oldValue    String
  newValue    String
  operator    String
  reason      String?
  createdAt   DateTime       @default(now())
  knowledge   KnowledgePoint @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)
}

model Template {
  id          String            @id @default(cuid())
  name        String
  type        String
  templateKey String?
  structure   Json
  params      Json
  steps       Json
  version     Int               @default(1)
  status      String            @default("draft")
  knowledgeId String?
  createdBy   String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  publishedAt DateTime?
  qualities   QuestionQuality[]
  knowledge   KnowledgeConcept? @relation("TemplateConcept", fields: [knowledgeId], references: [id])
  creator     Admin             @relation(fields: [createdBy], references: [id])
  versions    TemplateVersion[]
}

model TemplateVersion {
  id         String   @id @default(cuid())
  templateId String
  version    Int
  structure  Json
  params     Json
  steps      Json
  createdBy  String
  createdAt  DateTime @default(now())
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model QuestionQuality {
  id         String    @id @default(cuid())
  templateId String
  checkType  String
  status     String
  details    Json
  sampleData Json?
  detectedAt DateTime  @default(now())
  resolvedAt DateTime?
  template   Template  @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String
  changes   Json
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  admin     Admin    @relation(fields: [userId], references: [id])
}

model Assessment {
  id             String   @id @default(cuid())
  userId         String
  type           String
  score          Int
  scoreRangeLow  Int
  scoreRangeHigh Int
  knowledgeData  Json
  completedAt    DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LearningPath {
  id            String           @id @default(cuid())
  userId        String
  name          String
  type          String
  status        String           @default("active")
  knowledgeData String           @default("[]")
  generatedAt   DateTime         @default(now())
  expiresAt     DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  adjustments   PathAdjustment[]
  weeklyReports WeeklyReport[]

  @@index([userId, status])
}

model PathAdjustment {
  id        String       @id @default(cuid())
  pathId    String
  type      String
  trigger   String
  changes   String       @default("{}")
  createdAt DateTime     @default(now())
  path      LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)

  @@index([pathId, createdAt])
}

model WeeklyReport {
  id              String       @id @default(cuid())
  pathId          String
  weekStart       DateTime
  weekEnd         DateTime
  summary         String       @default("{}")
  staleKnowledge  String       @default("[]")
  recommendations String       @default("{}")
  viewed          Boolean      @default(false)
  createdAt       DateTime     @default(now())
  path            LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)

  @@index([pathId, weekStart])
}
