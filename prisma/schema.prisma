generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                         String                 @id @default(cuid())
  email                      String                 @unique
  name                       String?
  password                   String
  grade                      Int
  targetScore                Int                    @default(90)
  createdAt                  DateTime               @default(now())
  updatedAt                  DateTime               @updatedAt
  initialAssessmentCompleted Boolean                @default(false)
  initialAssessmentScore     Int?
  initialAssessmentDate      DateTime?
  reviewAssessmentCompleted  Boolean                @default(false)
  reviewAssessmentScore      Int?
  reviewAssessmentDate       DateTime?
  currentLevel               Int                    @default(0)
  startingScoreCalibrated    Boolean                @default(false)
  calibratedStartingScore    Int?
  selectedSubject            String?
  selectedTextbookId         String?
  studyProgress              Int                    @default(0)
  semesterStart              DateTime?
  semesterEnd                DateTime?
  includeStale               Boolean                @default(false)
  pathUpdateMode             String                 @default("auto")
  weeklyReportDay            Int                    @default(0)
  accounts                   Account[]
  admin                      Admin?
  assessments                Assessment[]
  attempts                   Attempt[]
  learningPaths              LearningPath[]
  ocrTasks                   OCRTask[]
  sessions                   Session[]
  enabledKnowledge           UserEnabledKnowledge[]
  knowledge                  UserKnowledge[]
  studentAbilities           StudentAbility[]
  predictionLogs             PredictionLog[]
}

model Question {
  id              String   @id @default(cuid())
  type            String
  difficulty      Int
  content         String   @default("{}")
  answer          String
  hint            String?
  knowledgePoints String   @default("[]")
  createdBy       String?
  isAI            Boolean  @default(false)
  createdAt       DateTime @default(now())
  params          String?  @default("{}")
  stepTypes       String?  @default("[]")
  templateId      String?
  generatedFrom   String? // Reference to GeneratedQuestion.id
  complexitySpec  String?  @default("{}") // Complexity spec from generation

  // Complexity feature extraction fields
  cognitiveLoad       Float? // [0, 1] 认知负荷
  reasoningDepth      Float? // [0, 1] 推理深度
  complexity          Float? // [0, 1] 综合复杂度
  extractionStatus    String    @default("PENDING") // PENDING | SUCCESS | FAILED
  featuresExtractedAt DateTime?
  extractionError     String? // 失败原因记录
  extractionModel     String?   @default("gemma-4-31b-it-v1")

  steps QuestionStep[]

  @@index([extractionStatus])
}

// UOK State Persistence - stores student and question learning state
model UOKState {
  id           String   @id @default(cuid())
  studentId    String
  knowledge    String   @default("{}") // JSON: Map<string, number>
  attemptCount Int      @default(0)
  correctCount Int      @default(0)
  embedding    String? // Base64 encoded Float32Array
  lastUpdated  DateTime @default(now())

  @@unique([studentId])
  @@index([studentId])
}

// Separate table for question-level state
model UOKQuestionState {
  id           String   @id @default(cuid())
  questionId   String   @unique
  topic        String?
  attemptCount Int      @default(0)
  correctCount Int      @default(0)
  embedding    String? // Base64 encoded Float32Array
  lastUpdated  DateTime @default(now())
}

model QuestionStep {
  id         String        @id @default(cuid())
  questionId String
  stepNumber Int
  expression String
  answer     String
  hint       String?
  inputType  String?
  keyboard   String?
  tolerance  Float?
  type       String?
  attempts   AttemptStep[]
  question   Question      @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model Attempt {
  id          String        @id @default(cuid())
  userId      String
  mode        String
  score       Int
  duration    Int
  startedAt   DateTime      @default(now())
  completedAt DateTime?
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  steps       AttemptStep[]
}

model AttemptStep {
  id             String        @id @default(cuid())
  attemptId      String
  questionStepId String?
  stepNumber     Int
  userAnswer     String
  isCorrect      Boolean
  duration       Int
  submittedAt    DateTime      @default(now())
  questionStep   QuestionStep? @relation(fields: [questionStepId], references: [id])
  attempt        Attempt       @relation(fields: [attemptId], references: [id], onDelete: Cascade)
}

model UserKnowledge {
  id               String         @id @default(cuid())
  userId           String
  knowledgePointId String
  mastery          Float
  lastPractice     DateTime       @default(now())
  practiceCount    Int            @default(0)
  knowledgePoint   KnowledgePoint @relation(fields: [knowledgePointId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, knowledgePointId])
}

model OCRTask {
  id        String   @id @default(cuid())
  userId    String
  imageUrl  String
  status    String
  result    String?  @default("{}")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Admin {
  id        String     @id @default(cuid())
  userId    String     @unique
  role      String     @default("viewer")
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  auditLogs AuditLog[]
  templates Template[]
}

model KnowledgeConcept {
  id        String           @id @default(cuid())
  name      String
  category  String?
  weight    Int              @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  instances KnowledgePoint[]
  templates Template[]       @relation("TemplateConcept")
}

model TextbookVersion {
  id        String    @id @default(cuid())
  name      String
  publisher String?
  grade     Int
  subject   String
  year      String?
  status    String    @default("active")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  chapters  Chapter[]

  @@unique([grade, subject, name])
  @@index([grade, subject, status])
}

model Chapter {
  id              String           @id @default(cuid())
  textbookId      String
  chapterNumber   Int
  chapterName     String
  sectionNumber   Int?
  sectionName     String?
  parentId        String?
  sort            Int              @default(0)
  parent          Chapter?         @relation("ChapterHierarchy", fields: [parentId], references: [id])
  children        Chapter[]        @relation("ChapterHierarchy")
  textbook        TextbookVersion  @relation(fields: [textbookId], references: [id])
  knowledgePoints KnowledgePoint[]

  @@index([textbookId, parentId])
}

model UserEnabledKnowledge {
  id        String   @id @default(cuid())
  userId    String
  nodeId    String
  nodeType  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, nodeId])
  @@index([userId, nodeType])
}

model KnowledgePoint {
  id            String                  @id @default(cuid())
  chapterId     String
  conceptId     String
  name          String
  weight        Int                     @default(0)
  inAssess      Boolean                 @default(true)
  status        String                  @default("active")
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  deletedAt     DateTime?
  concept       KnowledgeConcept        @relation(fields: [conceptId], references: [id])
  chapter       Chapter                 @relation(fields: [chapterId], references: [id])
  histories     KnowledgePointHistory[]
  userKnowledge UserKnowledge[]
}

model KnowledgePointHistory {
  id          String         @id @default(cuid())
  knowledgeId String
  field       String
  oldValue    String
  newValue    String
  operator    String
  reason      String?
  createdAt   DateTime       @default(now())
  knowledge   KnowledgePoint @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)
}

model Template {
  id          String            @id @default(cuid())
  name        String
  type        String
  templateKey String?
  structure   Json
  params      Json
  steps       Json
  version     Int               @default(1)
  status      String            @default("draft")
  knowledgeId String?
  source      String            @default("manual")
  skeletonIds String            @default("[]")
  createdBy   String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  publishedAt DateTime?
  qualities   QuestionQuality[]
  knowledge   KnowledgeConcept? @relation("TemplateConcept", fields: [knowledgeId], references: [id])
  creator     Admin             @relation(fields: [createdBy], references: [id])
  versions    TemplateVersion[]
}

model TemplateVersion {
  id         String   @id @default(cuid())
  templateId String
  version    Int
  structure  Json
  params     Json
  steps      Json
  createdBy  String
  createdAt  DateTime @default(now())
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model QuestionQuality {
  id         String    @id @default(cuid())
  templateId String
  checkType  String
  status     String
  details    Json
  sampleData Json?
  detectedAt DateTime  @default(now())
  resolvedAt DateTime?
  template   Template  @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String
  changes   Json
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  admin     Admin    @relation(fields: [userId], references: [id])
}

model Assessment {
  id             String   @id @default(cuid())
  userId         String
  type           String
  score          Int
  scoreRangeLow  Int
  scoreRangeHigh Int
  knowledgeData  Json
  completedAt    DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LearningPath {
  id            String           @id @default(cuid())
  userId        String
  name          String
  type          String
  status        String           @default("active")
  knowledgeData String           @default("[]")
  generatedAt   DateTime         @default(now())
  expiresAt     DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  adjustments   PathAdjustment[]
  weeklyReports WeeklyReport[]

  @@index([userId, status])
}

model PathAdjustment {
  id        String       @id @default(cuid())
  pathId    String
  type      String
  trigger   String
  changes   String       @default("{}")
  createdAt DateTime     @default(now())
  path      LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)

  @@index([pathId, createdAt])
}

model WeeklyReport {
  id              String       @id @default(cuid())
  pathId          String
  weekStart       DateTime
  weekEnd         DateTime
  summary         String       @default("{}")
  staleKnowledge  String       @default("[]")
  recommendations String       @default("{}")
  viewed          Boolean      @default(false)
  createdAt       DateTime     @default(now())
  path            LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)

  @@index([pathId, weekStart])
}

model Skeleton {
  id         String   @id // 如 "compute_sqrt"
  stepType   String // 如 "COMPUTE_SQRT"
  name       String // 中文名，如 "计算二次根式"
  config     Json // 输入类型、键盘类型、验证规则
  status     String   @default("pending") // pending | approved | production
  source     String // "ai_generated" | "manual"
  createdAt  DateTime @default(now())
  approvedBy String?
}

// ============================================================
// Prediction Service - 学生预测相关
// ============================================================

model StudentAbility {
  id          String   @id @default(cuid())
  userId      String
  nodeId      String // 知识点 ID，如 "algebra"
  ability     Float // IRT theta 参数 [-2, 2]
  sampleSize  Int      @default(0) // 样本数量
  lastUpdated DateTime @default(now())
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, nodeId])
  @@index([userId])
  @@index([nodeId])
}

model PredictionLog {
  id         String   @id @default(cuid())
  userId     String
  questionId String?
  predicted  Float // 预测概率 [0, 1]
  actual     Boolean? // 实际结果（后续更新）
  metadata   Json? // 额外元数据
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([createdAt])
}

// ============================================================
// QuestionGenerator - 实验态题目
// ============================================================

// GeneratedQuestion - 实验态题目
model GeneratedQuestion {
  id      String @id @default(cuid())
  batchId String

  // 题目内容
  type    String  @default("calculation")
  content String  @default("{}")
  answer  String
  hint    String?

  // 复杂度规范（生成目标）
  complexitySpec String

  // 生成元数据
  engine      String
  generatedAt DateTime @default(now())

  // Promotion 状态
  promotionStatus String    @default("PENDING")
  promotionScore  Float?
  promotedAt      DateTime?
  auditReason     String?

  @@index([batchId])
  @@index([promotionStatus])
}

// ============================================================
// RL Adaptive Engine - Thompson Sampling + IRT
// ============================================================

model RLModelVersion {
  id          String   @id @default(cuid())
  version     String   @unique
  algorithm   String

  bucketSize  Float    @default(0.5)
  priorAlpha  Float    @default(1)
  priorBeta   Float    @default(1)

  trainedAt   DateTime?

  avgReward       Float?
  totalSelections Int      @default(0)

  status      String   @default("TRAINING")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  arms        RLBanditArm[]
  logs        RLTrainingLog[]

  @@index([status])
}

model RLBanditArm {
  id          String   @id @default(cuid())
  modelId     String
  deltaC      Float

  alpha       Int      @default(1)
  beta        Int      @default(1)

  pullCount   Int      @default(0)
  successCount Int     @default(0)
  avgReward   Float?

  updatedAt   DateTime @updatedAt

  model       RLModelVersion @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@unique([modelId, deltaC])
}

model RLTrainingLog {
  id          String   @id @default(cuid())
  modelId     String

  eventId     String   @unique
  attemptId   String

  userId      String
  questionId  String

  knowledgePointId   String
  recommendationId   String
  preAccuracy        Float

  stateTheta      Float
  selectedDeltaC  Float
  reward          Float

  postAccuracy    Float?
  leDelta         Float?

  createdAt       DateTime @default(now())

  model       RLModelVersion @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([attemptId])
  @@index([modelId, userId])
  @@index([knowledgePointId])
  @@index([recommendationId])
}

model IRTStudentState {
  id              String   @id @default(cuid())
  userId          String   @unique

  theta           Float    @default(0)
  confidence      Float    @default(1)

  responseCount   Int      @default(0)

  lastEstimatedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([lastEstimatedAt])
  @@index([responseCount])
  @@index([theta])
}

model LEKnowledgePointState {
  id              String   @id @default(cuid())
  userId          String
  knowledgePointId String

  correct         Int      @default(0)
  total           Int      @default(0)
  accuracy        Float    @default(0.5)

  lastUpdatedAt   DateTime @default(now())

  @@unique([userId, knowledgePointId])
  @@index([userId])
  @@index([knowledgePointId])
}
