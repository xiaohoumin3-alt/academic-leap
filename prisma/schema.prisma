// Prisma Schema for 学力跃迁 (Academic Leap)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 用户模型
model User {
  id          String    @id @default(cuid())
  email       String    @unique
  name        String?
  password    String
  grade       Int       // 年级: 1-12
  targetScore Int       @default(90) // 目标分数
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // 关联
  attempts      Attempt[]
  knowledge     UserKnowledge[]
  ocrTasks      OCRTask[]
  accounts      Account[]
  sessions      Session[]
}

// 题目模型
model Question {
  id             String    @id @default(cuid())
  type           String    // calculation/geometry/algebra
  difficulty     Int       // 1-5
  content        String   @default("{}") // 题目内容（JSON字符串）
  answer         String
  hint           String?
  knowledgePoints String  @default("[]") // 知识点标签(JSON字符串)
  createdBy      String?   // admin id
  isAI           Boolean   @default(false)
  createdAt      DateTime  @default(now())

  // 关联
  steps    QuestionStep[]
}

// 题目步骤模型
model QuestionStep {
  id         String   @id @default(cuid())
  questionId String
  stepNumber Int
  expression String
  answer     String
  hint       String?

  question   Question      @relation(fields: [questionId], references: [id], onDelete: Cascade)
  attempts   AttemptStep[]
}

// 练习记录
model Attempt {
  id          String    @id @default(cuid())
  userId      String
  mode        String    // training/diagnostic
  score       Int
  duration    Int       // 秒
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  steps       AttemptStep[]
}

// 练习步骤记录
model AttemptStep {
  id            String   @id @default(cuid())
  attemptId     String
  questionStepId String?
  stepNumber    Int
  userAnswer    String
  isCorrect     Boolean
  duration      Int      // 毫秒
  submittedAt   DateTime @default(now())

  attempt       Attempt         @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionStep  QuestionStep?   @relation(fields: [questionStepId], references: [id], onDelete: SetNull)
}

// 用户知识点掌握
model UserKnowledge {
  id             String    @id @default(cuid())
  userId         String
  knowledgePoint String
  mastery        Float     // 0-1 掌握度
  lastPractice   DateTime  @default(now())
  practiceCount  Int       @default(0)

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, knowledgePoint])
}

// OCR识别任务
model OCRTask {
  id         String    @id @default(cuid())
  userId     String
  imageUrl   String
  status     String    // pending/processing/completed/failed
  result     String? @default("{}") // JSON字符串
  createdAt  DateTime  @default(now())

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// NextAuth.js Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
