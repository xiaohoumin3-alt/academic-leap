# Database
# 开发环境: 使用本地 SQLite
# DATABASE_URL="file:./dev.db"

# 生产环境: 使用 Supabase PostgreSQL (免费)
# 1. 注册 https://supabase.com 并创建项目
# 2. 复制连接字符串 (Settings → Database → Connection string)
# 3. 格式: postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
DATABASE_URL="postgresql://user:password@db.xxx.supabase.co:5432/postgres"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"

# Google Gemini AI
GEMINI_API_KEY="your-gemini-api-key"

# Google Vision API (用于手写OCR)
GOOGLE_VISION_API_KEY="your-google-vision-api-key"

# App URL
APP_URL="http://localhost:3000"
